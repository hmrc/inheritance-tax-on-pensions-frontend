# microservice specific routes

->          /hmrc-frontend                               hmrcfrontend.Routes

GET         /                                            controllers.IndexController.onPageLoad()

GET         /assets/*file                                controllers.Assets.versioned(path="/public", file: Asset)

GET         /refresh-session                             controllers.KeepAliveController.keepAlive()

GET         /there-is-a-problem                          controllers.JourneyRecoveryController.onPageLoad(continueUrl: Option[RedirectUrl] ?= None)

GET         /account/sign-out-survey                     controllers.auth.AuthController.signOut()
GET         /account/sign-out                            controllers.auth.AuthController.signOutNoSurvey()
GET         /account/signed-out                          controllers.auth.SignedOutController.onPageLoad()

GET         /unauthorised                                controllers.UnauthorisedController.onPageLoad()

GET         /:srn/report-inheritance-tax-on-pension      controllers.SubmissionListController.onPageLoad(srn: Srn)

GET         /:srn/start-report-you-will-need             controllers.WhatYouWillNeedController.onPageLoad(srn: Srn)
POST        /:srn/start-report-you-will-need             controllers.WhatYouWillNeedController.onSubmit(srn: Srn)

GET         /:srn/enter-inheritance-tax-reference        controllers.InheritanceTaxReferenceController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/enter-inheritance-tax-reference        controllers.InheritanceTaxReferenceController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-inheritance-tax-reference       controllers.InheritanceTaxReferenceController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-inheritance-tax-reference       controllers.InheritanceTaxReferenceController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/name-of-deceased                       controllers.IndividualNameController.onPageLoad(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.Deceased)
POST        /:srn/name-of-deceased                       controllers.IndividualNameController.onSubmit(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.Deceased)
GET         /:srn/change-name-of-deceased                controllers.IndividualNameController.onPageLoad(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.Deceased)
POST        /:srn/change-name-of-deceased                controllers.IndividualNameController.onSubmit(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.Deceased)

GET         /:srn/enter-national-insurance-number        controllers.NinoOrReasonController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/enter-national-insurance-number        controllers.NinoOrReasonController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-national-insurance-number       controllers.NinoOrReasonController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-national-insurance-number       controllers.NinoOrReasonController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/enter-birth-death-date                 controllers.BirthDeathDatesController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/enter-birth-death-date                 controllers.BirthDeathDatesController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-birth-death-date                controllers.BirthDeathDatesController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-birth-death-date                controllers.BirthDeathDatesController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/pr-individual-or-organisation         controllers.PrTypeController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/pr-individual-or-organisation         controllers.PrTypeController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-pr-individual-or-organisation  controllers.PrTypeController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-pr-individual-or-organisation  controllers.PrTypeController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/enter-name-pr                         controllers.IndividualNameController.onPageLoad(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrIndividual)
POST        /:srn/enter-name-pr                         controllers.IndividualNameController.onSubmit(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrIndividual)
GET         /:srn/change-name-pr                        controllers.IndividualNameController.onPageLoad(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrIndividual)
POST        /:srn/change-name-pr                        controllers.IndividualNameController.onSubmit(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrIndividual)

GET         /:srn/enter-organisation-name                controllers.OrganisationNameController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/enter-organisation-name                controllers.OrganisationNameController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-organisation-name               controllers.OrganisationNameController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-organisation-name               controllers.OrganisationNameController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/enter-name-pr-organisation             controllers.IndividualNameController.onPageLoad(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation)
POST        /:srn/enter-name-pr-organisation             controllers.IndividualNameController.onSubmit(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation)
GET         /:srn/change-name-pr-organisation            controllers.IndividualNameController.onPageLoad(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation)
POST        /:srn/change-name-pr-organisation            controllers.IndividualNameController.onSubmit(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation)

GET         /:srn/enter-pr-address                       controllers.AddressLookupStartController.start(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrIndividual)
GET         /:srn/change-pr-address                      controllers.AddressLookupStartController.start(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrIndividual)
GET         /:srn/address-lookup-continue/normalmode     controllers.AddressLookupContinueController.continue(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrIndividual, id: String ?= "")
GET         /:srn/address-lookup-continue/checkmode      controllers.AddressLookupContinueController.continue(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrIndividual, id: String ?= "")

GET         /:srn/enter-pr-organisation-address           controllers.AddressLookupStartController.start(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation)
GET         /:srn/change-pr-organisation-address          controllers.AddressLookupStartController.start(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation)
GET         /:srn/address-lookup-continue-org/normalmode  controllers.AddressLookupContinueController.continue(srn: Srn, mode: Mode = NormalMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation, id: String ?= "")
GET         /:srn/address-lookup-continue-org/checkmode   controllers.AddressLookupContinueController.continue(srn: Srn, mode: Mode = CheckMode, journeyRole: JourneyRole = JourneyRole.PrOrganisation, id: String ?= "")

GET         /:srn/scheme-receive-payment-notice          controllers.PaymentNoticeDateController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/scheme-receive-payment-notice          controllers.PaymentNoticeDateController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-scheme-receive-payment-notice   controllers.PaymentNoticeDateController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-scheme-receive-payment-notice   controllers.PaymentNoticeDateController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/check-your-answers                     controllers.CheckYourAnswersController.onPageLoad(srn: Srn)
POST        /:srn/check-your-answers                     controllers.CheckYourAnswersController.onSubmit(srn: Srn)

GET         /:srn/psa-declaration                        controllers.PsaDeclarationController.onPageLoad(srn: Srn)
POST        /:srn/psa-declaration                        controllers.PsaDeclarationController.onSubmit(srn: Srn)
GET         /:srn/pspDeclaration                         controllers.PspDeclarationController.onPageLoad(srn: Srn)
POST        /:srn/pspDeclaration                         controllers.PspDeclarationController.onSubmit(srn: Srn)

GET         /:srn/ihtp-report-submitted                  controllers.ConfirmationController.onPageLoad(srn: Srn)

GET         /:srn/pr-submit-payment-notice               controllers.DidPrSubmitController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/pr-submit-payment-notice               controllers.DidPrSubmitController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-pr-submit-payment-notice        controllers.DidPrSubmitController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-pr-submit-payment-notice        controllers.DidPrSubmitController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/are-beneficiaries-known              controllers.AreBeneficiariesKnownController.onPageLoad(srn: Srn, mode: Mode = NormalMode)
POST        /:srn/are-beneficiaries-known              controllers.AreBeneficiariesKnownController.onSubmit(srn: Srn, mode: Mode = NormalMode)
GET         /:srn/change-are-beneficiaries-known       controllers.AreBeneficiariesKnownController.onPageLoad(srn: Srn, mode: Mode = CheckMode)
POST        /:srn/change-are-beneficiaries-known       controllers.AreBeneficiariesKnownController.onSubmit(srn: Srn, mode: Mode = CheckMode)

GET         /:srn/select-beneficiary-type/$index<[1-2]?[0-9]>  controllers.beneficiary.BeneficiaryTypeController.onPageLoad(srn: Srn, index: Int, mode: Mode = NormalMode)
POST        /:srn/select-beneficiary-type/$index<[1-2]?[0-9]>  controllers.beneficiary.BeneficiaryTypeController.onSubmit(srn: Srn, index: Int, mode: Mode = NormalMode)
GET         /:srn/change-beneficiary-type/$index<[1-2]?[0-9]>  controllers.beneficiary.BeneficiaryTypeController.onPageLoad(srn: Srn, index: Int, mode: Mode = CheckMode)
POST        /:srn/change-beneficiary-type/$index<[1-2]?[0-9]>  controllers.beneficiary.BeneficiaryTypeController.onSubmit(srn: Srn, index: Int, mode: Mode = CheckMode)

